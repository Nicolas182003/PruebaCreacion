# Variables de entorno de ejemplo
# Copia este archivo como .env y completa con tus credenciales reales
# ⚠️ NUNCA subas el archivo .env real a GitHub

# Base de datos TimescaleDB
DB_HOST=localhost
DB_PORT=5433
DB_NAME=db_infra
DB_USER=admin_infra
DB_PASSWORD=TU_PASSWORD_AQUI
PORT=3000

# Motor de Correo (Gmail)
# Para obtener SMTP_PASS: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
